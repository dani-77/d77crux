# Description:cmus is a small, fast and powerful console music player for Unix-like operating systems.
# URL:https://cmus.github.io/
# Maintainer: dani77
# Depends on:

name=cmus
version=2.10.0
release=1
source=(https://github.com/cmus/cmus/archive/refs/tags/v2.10.0.tar.gz)

build() {
	cd $name-$version
	./configure
	make
	make DESTDIR=$PKG install
	rm -rf $PKG/usr/info
}
